{
  "name": "ingestion",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/index.ts",
    "scrape": "tsx src/scripts/scrape.ts",
    "scrub-pii": "tsx src/scripts/scrub-pii.ts",
    "start": "node dist/index.js",
    "test": "vitest run --exclude '**/*.integration.test.ts' --passWithNoTests",
    "test:integration": "vitest run integration.test",
    "lint": "tsc -p tsconfig.json --noEmit",
    "normalize": "tsx src/scripts/normalize.ts",
    "marts": "tsx src/scripts/marts.ts"
  },
  "dependencies": {
    "@seap/db": "workspace:*",
    "@seap/domain": "workspace:*",
    "@seap/scraper-clients": "workspace:*",
    "drizzle-orm": "^0.44.0",
    "graphile-worker": "^0.16.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
